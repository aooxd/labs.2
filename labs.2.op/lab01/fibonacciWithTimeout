#include <iostream>
#include <chrono>

using namespace std;

int main() {
    long long a = 0;
    long long b = 1;

    int count = 0;
    long long sum = 0;

    auto endTime = chrono::steady_clock::now() + chrono::seconds(5);

    while (chrono::steady_clock::now() < endTime) {
        long long value = a;

        long long temp = a;
        a = b;
        b = temp + b;

        count++;
        sum += value;

        cout << "Value: " << value
             << ", Total: " << sum
             << ", Average: " << (double)sum / count
             << endl;
    }

    cout << "Timeout reached." << endl;

    return 0;
}